{
  "court_name": "Supreme Court of India",
  "jurisdiction_code": "IN-SC",
  "margin_left_cm": 4.0,
  "margin_right_cm": 3.0,
  "margin_top_cm": 3.0,
  "margin_bottom_cm": 3.0,
  "font_body": "Times New Roman",
  "font_size_body": 12,
  "font_heading": "Times New Roman",
  "font_size_heading": 16,
  "font_heading_bold": true,
  "line_spacing": 2.0,
  "paragraph_spacing_before": 0,
  "paragraph_spacing_after": 14,
  "header_required": true,
  "header_format": "IN THE SUPREME COURT OF INDIA\n{bench_type} JURISDICTION\n\n{case_type} NO. {case_number} OF {year}",
  "footer_required": true,
  "footer_format": "Page {page_num} of {total_pages} | Advocate-on-Record: {advocate_name} | AOR No. {bar_number}",
  "stamp_paper_required": false,
  "stamp_paper_value": "0",
  "stamp_paper_currency": "INR",
  "notary_required": false,
  "verification_clause_required": true,
  "language_options": ["en"],
  "required_sections": [
    "cause_title",
    "synopsis_and_list_of_dates",
    "questions_of_law",
    "jurisdiction_clause",
    "facts",
    "grounds",
    "prayer",
    "verification",
    "advocate_on_record_signature"
  ],
  "section_order": [
    "cause_title",
    "synopsis_and_list_of_dates",
    "questions_of_law",
    "jurisdiction_clause",
    "facts",
    "grounds",
    "prayer",
    "verification",
    "advocate_on_record_signature"
  ],
  "fatal_defects": [
    "missing_cause_title",
    "incorrect_margins",
    "missing_verification",
    "missing_synopsis",
    "missing_questions_of_law",
    "missing_jurisdiction_clause",
    "not_advocate_on_record",
    "incorrect_line_spacing"
  ],
  "curable_defects": [
    "minor_formatting_inconsistency",
    "missing_page_numbers",
    "incorrect_font_size_by_1pt",
    "missing_index",
    "pagination_error"
  ],
  "annexure_rules": {
    "prefix": "Annexure",
    "numbering": "alphanumerical",
    "format": "Annexure P-{number}"
  }
}
